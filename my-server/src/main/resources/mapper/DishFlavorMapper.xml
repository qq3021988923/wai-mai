<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.yang.mapper.DishFlavorMapper">

    <select id="getByDishId" parameterType="Long">
        select * from dish_flavor where dish_id = #{id}
    </select>

    <insert id="insertBatch">
        insert into dish_flavor (dish_id, name, value) VALUES
        <foreach collection="flavors" item="df" separator=",">
            (#{df.dishId},#{df.name},#{df.value})
        </foreach>
    </insert>

    <delete id="deleteByDishId" parameterType="Long">
        delete from dish_flavor where dish_id = #{df.dishId}
    </delete>

</mapper>